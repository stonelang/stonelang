#ifndef ACTION
#define ACTION(M)
#endif

#ifndef FRONTEND_ACTION
#define FRONTEND_ACTION(M) ACTION(M)
#endif

#ifndef DRIVER_ACTION
#define DRIVER_ACTION(M) ACTION(M)
#endif

FRONTEND_ACTION(PrintHelp)
FRONTEND_ACTION(PrintHelpHidden)
FRONTEND_ACTION(PrintVersion)
FRONTEND_ACTION(PrintFeature)
FRONTEND_ACTION(Parse)
FRONTEND_ACTION(EmitParse)
FRONTEND_ACTION(ResolveImports)
FRONTEND_ACTION(TypeCheck)
FRONTEND_ACTION(EmitAST)
FRONTEND_ACTION(EmitIR)   
FRONTEND_ACTION(EmitBC)
FRONTEND_ACTION(EmitObject)  
FRONTEND_ACTION(EmitModule)   
FRONTEND_ACTION(MergeModules)
FRONTEND_ACTION(EmitAssembly)

DRIVER_ACTION(EmitLibrary)
DRIVER_ACTION(EmitExecutable)

#undef ACTION
#undef FRONTEND_ACTION
#undef DRIVER_ACTION